{
  "expo": {
    "name": "QuranDuel",
    "slug": "quran-duel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "quranduel",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2818"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soufi54.quranduel",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "QuranDuel utilise le microphone pour la recitation du Coran.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2818"
      },
      "package": "com.soufi54.quranduel",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "QuranDuel utilise le microphone pour la recitation du Coran."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "PLACEHOLDER"
      }
    }
  }
}
